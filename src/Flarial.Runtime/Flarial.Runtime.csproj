<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PlatformTarget>x64</PlatformTarget>
    <TargetFramework>net48</TargetFramework>

    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <Optimize>true</Optimize>
    <PublishRelease>true</PublishRelease>

    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <DeterministicSourcePaths>true</DeterministicSourcePaths>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>

    <!-- Injected by CI via /p:AnalyticsSecret=... and /p:AnalyticsEndpoint=...
         Empty in local/dev builds so Analytics becomes a no-op. -->
    <AnalyticsSecret Condition="'$(AnalyticsSecret)' == ''"></AnalyticsSecret>
    <AnalyticsEndpoint Condition="'$(AnalyticsEndpoint)' == ''">https://api.flarial.xyz/launcher/events/launch</AnalyticsEndpoint>
    <GeneratedAnalyticsConfigDir>$(MSBuildThisFileDirectory)obj\generated\</GeneratedAnalyticsConfigDir>
    <GeneratedAnalyticsConfig>$(GeneratedAnalyticsConfigDir)GeneratedAnalyticsConfig.cs</GeneratedAnalyticsConfig>
  </PropertyGroup>

  <Target Name="GenerateAnalyticsConfig" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <AnalyticsConfigContent>
<![CDATA[// <auto-generated/>
namespace Flarial.Runtime.Services%3B
static class AnalyticsBuildConfig
{
    internal const string Secret = "$(AnalyticsSecret)"%3B
    internal const string Endpoint = "$(AnalyticsEndpoint)"%3B
}
]]>
      </AnalyticsConfigContent>
    </PropertyGroup>
    <MakeDir Directories="$(GeneratedAnalyticsConfigDir)" />
    <WriteLinesToFile File="$(GeneratedAnalyticsConfig)" Lines="$(AnalyticsConfigContent)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <Compile Include="$(GeneratedAnalyticsConfig)" />
      <FileWrites Include="$(GeneratedAnalyticsConfig)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <Reference Include="System.Net.Http" />
    <Compile Include="..\AssemblyVersion.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Flarial.Unmanaged\Flarial.Unmanaged.csproj" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.SDK.Contracts" Version="10.0.19041.2" PrivateAssets="All" />
    <PackageReference Include="Microsoft.PowerShell.5.1.ReferenceAssemblies" Version="1.0.0" PrivateAssets="All" />
  </ItemGroup>

</Project>