<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Flarial.Launcher.ViewModels"
             xmlns:acrylicBlur="clr-namespace:Flarial.Launcher.Controls.AcrylicBlur"
             xmlns:spotlightDecorator="clr-namespace:Flarial.Launcher.Controls.SpotlightDecorator"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Flarial.Launcher.Views.MessageBoxView"
             x:DataType="vm:MessageBoxViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Styles/MessageBoxStyles.axaml"/>
    </UserControl.Styles>
    
    <Grid>
        <Panel Name="Scrim"
               Background="#39000000"
               Opacity="0"/>
        
        <acrylicBlur:AcrylicBlur Blur="25" 
                                 CornerRadius="15"
                                 Name="DialogPanel"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 MinWidth="400" MinHeight="200"
                                 MaxWidth="650" MaxHeight="350">
            <acrylicBlur:AcrylicBlur.RenderTransform>
                <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
            </acrylicBlur:AcrylicBlur.RenderTransform>
            <acrylicBlur:AcrylicBlur.Effect>
                <DropShadowEffect Opacity="0.75"
                                  Color="Black"
                                  BlurRadius="35"
                                  OffsetX="0" OffsetY="0"/>
            </acrylicBlur:AcrylicBlur.Effect>
            <acrylicBlur:AcrylicBlur.Material>
                <ExperimentalAcrylicMaterial MaterialOpacity="0.1" 
                                             TintOpacity="1" 
                                             PlatformTransparencyCompensationLevel="0"
                                             TintColor="{StaticResource BackgroundColor}"/>
            </acrylicBlur:AcrylicBlur.Material>
            
            <Border CornerRadius="15"
                    Padding="10"
                    BorderBrush="{StaticResource BackgroundBorderColor}"
                    BorderThickness="{StaticResource ButtonBorderThickness}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource BackgroundColor}" Opacity="0.75"/>
                </Border.Background>
                
                <Grid RowDefinitions="Auto, *, Auto">
                
                    <Grid HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Title}" 
                                   TextWrapping="WrapWithOverflow"
                                   Foreground="{StaticResource ForegroundColor}" 
                                   FontSize="22" 
                                   FontWeight="SemiBold" />
                        <Border Margin="0,0,0,0" VerticalAlignment="Bottom" Background="#FF2438" Height="3" />
                    </Grid>
                    
                    <TextBlock Grid.Row="1" 
                               Margin="0,10,0,10"
                               Text="{Binding Message}" 
                               TextWrapping="WrapWithOverflow"
                               Foreground="White"
                               FontSize="16"/>
                    
                    <VisualLayerManager Grid.Row="2">
                        <spotlightDecorator:SpotlightDecorator SpotlightColor="#9f9f9f" SpotlightRadius="120">
                            <ItemsControl ItemsSource="{Binding Buttons}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"
                                                    HorizontalAlignment="Stretch"
                                                    ColumnSpacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Template>
                                    <ControlTemplate>
                                        <ItemsPresenter Name="PART_ItemsPresenter"
                                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Command="{Binding $parent[UserControl].((vm:MessageBoxViewModel)DataContext).SelectButtonCommand}"
                                                CommandParameter="{Binding}"
                                                MinWidth="80"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </spotlightDecorator:SpotlightDecorator>
                    </VisualLayerManager>
                </Grid>
            </Border>
        </acrylicBlur:AcrylicBlur>
    </Grid>
</UserControl>
