                            </RadioButton.Tag>
                        </RadioButton>
                        <RadioButton IsEnabled="True" Classes="SettingsRadioButton" Name="VersionsPageButton" Grid.Row="1" Content="Versions" Command="{Binding NavigateCommand}" CommandParameter="{x:Static types:PageTransitions.SettingsVersionsPage}">
                            <RadioButton.Tag>
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="White" Data="M4.5,7A3.477,3.477,0,0,1,2.025,5.975L.5,4.62a1.5,1.5,0,0,1,2-2.24L4.084,3.794A.584.584,0,0,0,4.5,4a.5.5,0,0,0,.353-.146L8.466.414a1.5,1.5,0,0,1,2.068,2.172L6.948,6A3.449,3.449,0,0,1,4.5,7ZM24,3.5A1.5,1.5,0,0,0,22.5,2h-8a1.5,1.5,0,0,0,0,3h8A1.5,1.5,0,0,0,24,3.5ZM6.948,14l3.586-3.414A1.5,1.5,0,0,0,8.466,8.414l-3.613,3.44a.5.5,0,0,1-.707,0L2.561,10.268A1.5,1.5,0,0,0,.439,12.39l1.586,1.585A3.5,3.5,0,0,0,6.948,14ZM24,11.5A1.5,1.5,0,0,0,22.5,10h-8a1.5,1.5,0,0,0,0,3h8A1.5,1.5,0,0,0,24,11.5ZM6.948,22l3.586-3.414a1.5,1.5,0,0,0-2.068-2.172l-3.613,3.44A.5.5,0,0,1,4.5,20a.584.584,0,0,1-.416-.206L2.5,18.38a1.5,1.5,0,0,0-2,2.24l1.523,1.355A3.5,3.5,0,0,0,6.948,22ZM24,19.5A1.5,1.5,0,0,0,22.5,18h-8a1.5,1.5,0,0,0,0,3h8A1.5,1.5,0,0,0,24,19.5Z"/>
                                </Viewbox>                    
                            </RadioButton.Tag>
                        </RadioButton>
                        <RadioButton Name="ConfigsPageButton" Classes="SettingsRadioButton" Grid.Row="2" Content="Configs" Command="{Binding NavigateCommand}" CommandParameter="{x:Static types:PageTransitions.SettingsConfigsPage}">
                            <RadioButton.Tag>
                                <Viewbox Width="20" Height="20">
                                    <Grid>
                                        <Path Fill="White" Data="M66.074,228.731C81.577,123.379,179.549,50.542,284.901,66.045c35.944,5.289,69.662,20.626,97.27,44.244l-24.853,24.853   c-8.33,8.332-8.328,21.84,0.005,30.17c3.999,3.998,9.423,6.245,15.078,6.246h97.835c11.782,0,21.333-9.551,21.333-21.333V52.39   c-0.003-11.782-9.556-21.331-21.338-21.329c-5.655,0.001-11.079,2.248-15.078,6.246L427.418,65.04   C321.658-29.235,159.497-19.925,65.222,85.835c-33.399,37.467-55.073,83.909-62.337,133.573   c-2.864,17.607,9.087,34.202,26.693,37.066c1.586,0.258,3.188,0.397,4.795,0.417C50.481,256.717,64.002,244.706,66.074,228.731z"/>
                                        <Path Fill="White" Data="M479.429,256.891c-16.108,0.174-29.629,12.185-31.701,28.16C432.225,390.403,334.253,463.24,228.901,447.738   c-35.944-5.289-69.662-20.626-97.27-44.244l24.853-24.853c8.33-8.332,8.328-21.84-0.005-30.17   c-3.999-3.998-9.423-6.245-15.078-6.246H43.568c-11.782,0-21.333,9.551-21.333,21.333v97.835   c0.003,11.782,9.556,21.331,21.338,21.329c5.655-0.001,11.079-2.248,15.078-6.246l27.733-27.733   c105.735,94.285,267.884,85.004,362.17-20.732c33.417-37.475,55.101-83.933,62.363-133.615   c2.876-17.605-9.064-34.208-26.668-37.084C482.655,257.051,481.044,256.91,479.429,256.891z"/>
                                    </Grid>
                                </Viewbox>
                            </RadioButton.Tag>
                        </RadioButton>
                        
                        <Button Grid.Row="3" Classes="ReturnButton" Command="{Binding NavigateCommand}" CommandParameter="{x:Static types:PageTransitions.HomePage}"/>

                    </Grid>
                </spotlightDecorator:SpotlightDecorator>
            </VisualLayerManager>
            
        </Grid>
        <Grid Grid.Column="2" Height="470" Width="555" Name="UserControlGrid">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>
            
            <ContentControl Name="SettingsGeneralViewControl" Content="{Binding SettingsGeneralViewModel}">
                <ContentControl.RenderTransform>
                    <TranslateTransform Y="0"/>
                </ContentControl.RenderTransform>
            </ContentControl>
            
            <ContentControl Name="SettingsVersionsViewControl" Content="{Binding SettingsVersionsViewModel}">
                <ContentControl.RenderTransform>
                    <TranslateTransform Y="500"/>
                </ContentControl.RenderTransform>
            </ContentControl>
            
            <ContentControl Name="SettingsConfigsViewControl" Content="{Binding SettingsConfigsViewModel}">
                <ContentControl.RenderTransform>
                    <TranslateTransform Y="1000"/>
                </ContentControl.RenderTransform>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
