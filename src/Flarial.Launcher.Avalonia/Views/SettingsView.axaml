<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Flarial.Launcher.ViewModels"
             xmlns:local="clr-namespace:Flarial.Launcher.Views"
             xmlns:types="clr-namespace:Flarial.Launcher.Types"
             xmlns:spotlightDecorator="clr-namespace:Flarial.Launcher.Controls.SpotlightDecorator"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Flarial.Launcher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Width="800" Height="500">
    <UserControl.Clip>
        <RectangleGeometry Rect="0,0,800,500"/>
    </UserControl.Clip>
    <Grid Margin="15" ColumnDefinitions="200,15,*">
        <Border Grid.Column="0" IsHitTestVisible="False" Background="#201A1B" BorderThickness="{StaticResource ButtonBorderThickness}" BorderBrush="{StaticResource BackgroundBorderColor}" CornerRadius="20"/>
        <Grid Grid.Column="0" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" Margin="20" VerticalAlignment="Top" HorizontalAlignment="Stretch" ColumnDefinitions="Auto,Auto">
                <Image Grid.Column="0" Source="/Assets/icon.webp" Height="40" Margin="0" />
                <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="Settings" VerticalAlignment="Center" FontSize="22" Foreground="White"/>
            </Grid>
            <VisualLayerManager Grid.Row="1">
                <spotlightDecorator:SpotlightDecorator SpotlightColor="#9f9f9f" SpotlightRadius="120">
                    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="Transparent">
                        <RadioButton Grid.Row="0" IsChecked="True" Classes="SettingsRadioButton" Name="GeneralPageButton" Command="{Binding NavigateCommand}" CommandParameter="{x:Static types:PageTransitions.SettingsGeneralPage}" Content="General">
                            <RadioButton.Tag>
