<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Button.SettingsButton">
        <Setter Property="Height" Value="45"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="MainBorder"
                        Width="300"
                        Height="45"
                        Background="{StaticResource SecondaryColor}"
                        CornerRadius="10"
                        BorderThickness="{StaticResource ButtonBorderThickness}" BorderBrush="{StaticResource SecondaryBorderColor}">

                    <Grid>
                        <Border CornerRadius="10" Background="White" Opacity="0.0">
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="Opacity" Value="0.025"/>
                                </Style>
                            </Border.Styles>
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                                </Transitions>
                            </Border.Transitions>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" IsHitTestVisible="False">
                            <Viewbox Height="22.5">
                                <Path Name="SettingsIcon"
                                      Data="M0.0553735 13.1495C0.920187 10.5965 2.34479 8.253 4.22453 6.26696C4.54238 5.93112 5.04107 5.81141 5.48755 5.96381L9.97974 7.49699C11.1976 7.91244 12.5377 7.3068 12.973 6.14428C13.0157 6.02995 13.0487 5.91253 13.0715 5.79329L13.9273 1.30928C14.0124 0.863458 14.3711 0.510796 14.8355 0.416429C16.1942 0.140393 17.5872 0 18.9985 0C20.409 0 21.8012 0.140235 23.1591 0.415922C23.6233 0.510194 23.982 0.862635 24.0673 1.3083L24.9255 5.7931C25.1576 7.00758 26.3769 7.81256 27.6494 7.5911C27.7747 7.56931 27.8976 7.53786 28.0172 7.49706L32.5095 5.96381C32.9559 5.81141 33.4545 5.93112 33.7724 6.26696C35.6522 8.253 37.0767 10.5965 37.9418 13.1495C38.0875 13.5802 37.9468 14.0523 37.5853 14.3453L33.9442 17.2961C32.9585 18.0952 32.8379 19.5058 33.6749 20.4468C33.7572 20.5393 33.8474 20.6253 33.9442 20.7038L37.5853 23.6547C37.9468 23.9476 38.0875 24.4198 37.9418 24.8505C37.0767 27.4036 35.6522 29.7471 33.7724 31.733C33.4545 32.0688 32.9559 32.1885 32.5095 32.0361L28.0172 30.5029C26.7996 30.0877 25.4593 30.6933 25.0241 31.8556C24.9813 31.9699 24.9483 32.0874 24.9255 32.2072L24.0673 36.6917C23.982 37.1374 23.6233 37.4897 23.1591 37.5841C21.8012 37.8597 20.409 38 18.9985 38C17.5872 38 16.1942 37.8597 14.8355 37.5834C14.3711 37.489 14.0124 37.1365 13.9273 36.6908L13.0715 32.2069C12.8395 30.9924 11.62 30.1874 10.3477 30.4089C10.2225 30.4307 10.0995 30.4621 9.97994 30.5029L5.48755 32.0361C5.04107 32.1885 4.54238 32.0688 4.22453 31.733C2.34479 29.7471 0.920187 27.4036 0.0553735 24.8505C-0.0905133 24.4198 0.050152 23.9476 0.411681 23.6547L4.05274 20.7039C5.03859 19.9048 5.15917 18.4942 4.32208 17.5532C4.23977 17.4606 4.14969 17.3747 4.05277 17.2961L0.411681 14.3453C0.050152 14.0523 -0.0905133 13.5802 0.0553735 13.1495ZM13.2155 18.9998C13.2155 22.0614 15.8045 24.5433 18.9981 24.5433C22.1918 24.5433 24.7807 22.0614 24.7807 18.9998C24.7807 15.9382 22.1918 13.4563 18.9981 13.4563C15.8045 13.4563 13.2155 15.9382 13.2155 18.9998Z"
                                      Fill="White"/>
                            </Viewbox>
                            <TextBlock Name="SettingsText"
                                       Margin="10,0,0,0"
                                       Text="Settings"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="20"
                                       Foreground="#ffffff"
                                       />
                        </StackPanel>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="scale(0.90)"/>
        </Style>
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter.Value>
        </Setter>

        <!-- Mouse Over State -->
        <Style Selector="^:pointerover /template/ Border > Border">
            <Style.Animations>
                <Animation Duration="0:0:0.1" FillMode="Forward">
                    <KeyFrame Cue="100%">
                        <Setter Property="Background">
                            <SolidColorBrush Color="White" Opacity="0.1"/>
                        </Setter>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Disabled State -->
        <Style Selector="^:disabled /template/ Border#MainBorder">
            <Setter Property="Background" Value="#FF606060"/>
            <Setter Property="BorderBrush" Value="#FF606060"/>
        </Style>

        <Style Selector="^:disabled /template/ Path#SettingsIcon">
            <Setter Property="Fill" Value="#FFA0A0A0"/>
        </Style>

        <Style Selector="^:disabled /template/ TextBlock#SettingsText">
            <Setter Property="Foreground" Value="#FFA0A0A0"/>
        </Style>
    </Style>
</Styles>
