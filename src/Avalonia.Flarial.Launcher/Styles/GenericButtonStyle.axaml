<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Button.GenericButton">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="CornerRadius" Value="10"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Name="MainBorder" Background="{StaticResource PrimaryColor}" CornerRadius="{TemplateBinding CornerRadius}" RenderTransformOrigin="0.5,0.5" BorderThickness="{StaticResource ButtonBorderThickness}" BorderBrush="{StaticResource PrimaryBorderColor}">
                        <Grid>
                            <Border CornerRadius="10" Background="White" Opacity="0">
                                <Border.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="Opacity" Value="0.05"/>
                                    </Style>
                                </Border.Styles>
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock x:Name="OpenText" Margin="10,5,10,5" Text="{TemplateBinding Content}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource ForegroundColor}" FontSize="{TemplateBinding FontSize}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="scale(0.90)"/>
        </Style>
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter.Value>
        </Setter>

        <Style Selector="^:disabled /template/ Border#MainBorder">
            <Setter Property="Background" Value="#FF606060"/>
            <Setter Property="BorderBrush" Value="#FF606060"/>
        </Style>

        <Style Selector="^:disabled /template/ TextBlock#OpenText">
            <Setter Property="Foreground" Value="#FFA0A0A0"/>
        </Style>
    </Style>
</Styles>
