<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <PlatformTarget>x64</PlatformTarget>
        <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>

        <NoWarn>IL2026,IL2104</NoWarn>

        <Optimize>true</Optimize>
        <PublishRelease>true</PublishRelease>

        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

        <ApplicationIcon>Assets/app.ico</ApplicationIcon>
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>

        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <DeterministicSourcePaths>true</DeterministicSourcePaths>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    </PropertyGroup>

    <PropertyGroup>
        <InvariantGlobalization>true</InvariantGlobalization>
        <SatelliteResourceLanguages>*</SatelliteResourceLanguages>

        <SelfContained>true</SelfContained>
        <PublishTrimmed>true</PublishTrimmed>
        <TrimmerRemoveSymbols>true</TrimmerRemoveSymbols>

        <PublishSingleFile>true</PublishSingleFile>
        <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
        <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    </PropertyGroup>

    <ItemGroup>
        <AvaloniaResource Include="Assets\**" />
        <Compile Include="..\AssemblyVersion.cs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Avalonia.Flarial.Runtime\Flarial.Runtime.csproj" PrivateAssets="All" />
        <ProjectReference Include="..\Avalonia.Flarial.Unmanaged\Flarial.Unmanaged.csproj" PrivateAssets="All" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="SkiaSharp" Version="3.119.4" />
        <PackageReference Include="Avalonia.HarfBuzz" Version="12.0.3" />

        <PackageReference Include="Avalonia.Skia" Version="12.0.3" />
        <PackageReference Include="Avalonia.Win32" Version="12.0.3" />

        <PackageReference Include="ReactiveUI.Avalonia" Version="12.0.1" />
        <PackageReference Include="ReactiveUI.SourceGenerators" Version="2.6.30" />
    </ItemGroup>
</Project>