<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Button.DiscordLoginButton">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Content" Value="Login With Discord"/>
        <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBorderColor}"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Name="MainBorder" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" RenderTransformOrigin="0.5,0.5" BorderThickness="{StaticResource ButtonBorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                        <Grid>
                            <Border CornerRadius="10" Background="White" Opacity="0">
                                <Border.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="Opacity" Value="0.05"/>
                                    </Style>
                                </Border.Styles>
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" IsHitTestVisible="False" Margin="10,0,10,0">
                                <Viewbox Height="25" Width="25" Margin="0,-5,10,0" Name="IconViewBox">
                                    <Path Fill="#ffffff" Data="M19.888 7.335a5.134 5.134 0 0 0-2.893-2.418a9.144 9.144 0 0 0-2.275-.508a9.963 9.963 0 0 0-.508 1.038a15.039 15.039 0 0 0-4.56 0a11.372 11.372 0 0 0-.519-1.038c-.752.082-1.493.249-2.208.497a5.123 5.123 0 0 0-2.904 2.44a16.176 16.176 0 0 0-1.91 9.717a16.562 16.562 0 0 0 4.98 2.528a4.339 4.339 0 0 0 1.104-1.777c-.54-.202-1.06-.45-1.557-.74c-.089-.122.254-.32.364-.354a11.826 11.826 0 0 0 10.037 0c.1 0 .453.232.364.354c-.441.342-1.424.585-1.59.828a7.4 7.4 0 0 0 1.105 1.69a16.628 16.628 0 0 0 4.99-2.53a16.232 16.232 0 0 0-2.02-9.727M8.669 14.7a1.943 1.943 0 0 1-1.92-1.955a1.943 1.943 0 0 1 1.92-1.91a1.942 1.942 0 0 1 1.933 1.965a1.943 1.943 0 0 1-1.933 1.9m6.625 0a1.943 1.943 0 0 1-1.932-1.944a1.932 1.932 0 1 1 3.865.034a1.932 1.932 0 0 1-1.933 1.899z"/>
                                </Viewbox>
                                
                                <TextBlock x:Name="OpenText" Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource ForegroundColor}" FontSize="{TemplateBinding FontSize}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="^:checked">
            <Setter Property="Content" Value="Logout"/>
            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorderColor}"/>
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="scale(0.90)"/>
        </Style>
        <Setter Property="Transitions">
            <Setter.Value>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter.Value>
        </Setter>

        <Style Selector="^:checked /template/ Viewbox#IconViewBox">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        
        <Style Selector="^:disabled /template/ Border#MainBorder">
            <Setter Property="Background" Value="#FF606060"/>
            <Setter Property="BorderBrush" Value="#FF606060"/>
        </Style>

        <Style Selector="^:disabled /template/ TextBlock#OpenText">
            <Setter Property="Foreground" Value="#FFA0A0A0"/>
        </Style>
    </Style>
</Styles>