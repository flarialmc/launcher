<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Flarial.Launcher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Flarial.Launcher.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Flarial.Launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app.ico" CanResize="False"
        Title="Flarial Launcher" Height="500" Width="800"
        SystemDecorations="None"
        Background="{x:Null}"
        TransparencyLevelHint="Transparent">
    <Window.Clip>
        <RectangleGeometry Rect="0,0,800,500"/>
    </Window.Clip>
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Grid>
        <Border Name="MainBorder" Background="{StaticResource WindowColor}" CornerRadius="25" ClipToBounds="True">
            <Grid>
                <Grid Background="Transparent" PointerPressed="DragWindow"/>
                <Grid>
                    <Grid.Effect>
                        <BlurEffect Radius="0"/>
                    </Grid.Effect>
                    
                    <ContentControl Name="HomeViewControl" Content="{Binding HomeViewModel}">
                        <ContentControl.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <TranslateTransform Y="0"/>
                            </TransformGroup>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl IsHitTestVisible="False" Opacity="0" Name="SettingsViewControl" Content="{Binding SettingsViewModel}">
                        <ContentControl.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                </Grid>
                
                <Canvas x:Name="ToolTipLayer"
                        IsHitTestVisible="False"
                        ZIndex="10000"/>
                
                <views:NotificationAreaView DataContext="{Binding NotificationArea}"/>
                
                <ContentControl Content="{Binding CurrentDialog}"
                                IsHitTestVisible="{Binding CurrentDialog, Converter={x:Static ObjectConverters.IsNotNull}}"
                                IsVisible="{Binding CurrentDialog, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:MessageBoxViewModel">
                            <views:MessageBoxView/>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Grid>
        </Border>

        <Popup Name="AdPopup"
               PlacementTarget="{Binding #MainBorder}"
               Placement="Bottom"
               HorizontalOffset="0"
               VerticalOffset="0"
               IsLightDismissEnabled="False"
               IsOpen="False">
            <Border Cursor="Hand"
                    Name="AdBorder"
                    Height="50"
                    Width="320"
                    CornerRadius="10"
                    Background="Black"
                    ClipToBounds="True"
                    PointerPressed="AdBorder_OnPointerPressed">
                <Border.RenderTransform>
                    <TranslateTransform Y="-60"/>
                </Border.RenderTransform>
                <Image Name="AdImage" Stretch="Fill"/>
            </Border>
        </Popup>
    </Grid>
</Window>
